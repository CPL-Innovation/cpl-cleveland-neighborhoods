# Copy to .env.local and fill in. .env.local is gitignored.
# Next.js loads .env.local automatically; the scan CLI + drizzle-kit load it via scan/env.mjs.

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL dev (Postgres.app): point at your local Postgres. Run `createdb cpl_neighborhoods`
# once, then `npm run db:push`.
DATABASE_URL=postgresql://<you>@localhost:5432/cpl_neighborhoods
# DEPLOYED (Supabase): use the POOLED / transaction connection string (port 6543).
# Dashboard → Project Settings → Database → Connection string → "Transaction" pooler.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Derivative JPEG storage ───────────────────────────────────────────────────
# Backend is auto-selected: local disk (public/derivatives/) unless the SUPABASE_*
# vars below are set. Force either way with STORAGE_BACKEND=local|supabase.
# STORAGE_BACKEND=local
#
# Supabase Storage (deployed) — project URL + service-role key (server-side only).
# Dashboard → Project Settings → API.
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# SUPABASE_DERIVATIVES_BUCKET=derivatives

# Gemini (already in your .env from the scan pipeline build).
GEMINI_API_KEY=<your-key>
# GEMINI_MODEL=gemini-3-flash-preview
